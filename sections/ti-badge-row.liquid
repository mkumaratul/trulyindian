{{ 'truly-indian-home.css' | asset_url | stylesheet_tag }}
<div class="ti-badge-row-img">
	<img src="{{ section.settings.image | asset_url }}" alt="{{ section.settings.alt }}" loading="lazy">
</div>
{% schema %}
{
	"name": "TI: Badge row (image)",
	"settings": [
		{
			"type": "select",
			"id": "image",
			"label": "Image",
			"default": "ti-badges-row1.png",
			"options": [
				{ "value": "ti-badges-row1.png", "label": "Row 1: Bold Flavours" },
				{ "value": "ti-badges-row2.png", "label": "Row 2: Scratch with Love" }
			]
		},
		{ "type": "text", "id": "alt", "label": "Alt text", "default": "Bold Flavours, Simple Ingredients, Handmade in India" }
	],
	"presets": [{ "name": "TI: Badge row (image)" }]
}
{% endschema %}
